# ----- Server -----
PORT=8787
# Comma-separated list of allowed origins for the mobile app / website (use * only in dev)
CORS_ORIGINS=*

# ----- LLM provider selection -----
# Primary provider. Registered providers live in src/llm/client.ts.
# Supported now: anthropic, sarvam   (planned: llama, openai)
LLM_PROVIDER=sarvam
# Fallback provider, used automatically only when the primary throws (API error,
# network failure, or unparseable JSON). Leave empty to disable fallback.
# Requires the fallback provider's credentials to also be set below.
LLM_FALLBACK_PROVIDER=anthropic

# Provider-neutral generation settings (apply to whichever provider is active).
# Default model is Claude Sonnet 4.6.
LLM_MODEL=claude-sonnet-4-6
# Optional: a different model for question generation (defaults to LLM_MODEL).
LLM_MODEL_GENERATION=claude-sonnet-4-6
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1200

# ----- Anthropic (Claude) credentials -----
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ----- Sarvam (OpenAI-compatible; set LLM_PROVIDER=sarvam to activate) -----
SARVAM_API_KEY=your-sarvam-key-here
SARVAM_MODEL=sarvam-30b
# Optional: override the Sarvam API base URL
SARVAM_BASE_URL=https://api.sarvam.ai/v1

# ----- Future providers (uncomment + register in src/llm/client.ts when added) -----
# LLAMA_BASE_URL=http://localhost:11434/v1
# LLAMA_API_KEY=
